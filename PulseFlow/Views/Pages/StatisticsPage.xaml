<Page x:Class="PulseFlow.Views.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:local="clr-namespace:PulseFlow.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      d:DataContext="{d:DesignInstance local:StatisticsPage, IsDesignTimeCreatable=False}"
      Title="StatisticsPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📊 통계 분석 (Analytics)" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>
            <TextBlock Text="데이터 조회 범위 : " VerticalAlignment="Center" Foreground="LightGray" Margin="0,0,10,0" FontSize="16"/>
            <ComboBox SelectedIndex="{Binding ViewModel.SelectedTimeRangeIndex}" Width="200" FontSize="14">
                <ComboBoxItem Content="최근 1시간 평균"/>
                <ComboBoxItem Content="최근 24시간 평균"/>
                <ComboBoxItem Content="전체 누적 데이터"/>
            </ComboBox>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Rows="1">

            <ui:Card Margin="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Machine_A" FontSize="22" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,75" HorizontalAlignment="Center"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineA_AvgTemp}" FromValue="0" ToValue="100" 
                                              TicksForeground="White" Foreground="White" FontWeight="Bold" 
                                              NeedleFill="DeepSkyBlue" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="60" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="60" ToValue="85" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="85" ToValue="100" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 온도" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineA_AvgTemp, StringFormat={}{0:F1} ℃}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DeepSkyBlue"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineA_AvgPress}" FromValue="0" ToValue="6" 
                                              TicksForeground="White" Foreground="White" FontWeight="Bold" 
                                              NeedleFill="Orange" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="3" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="3" ToValue="4.5" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="4.5" ToValue="6" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 압력" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineA_AvgPress, StringFormat={}{0:F2} atm}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Orange"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,50,0,0" BorderBrush="#333333" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="최고 온도 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineA_MaxTemp, StringFormat={}{0:F1} ℃}" FontWeight="Black" FontSize="20" Foreground="#FF5252" Grid.Row="1" Grid.Column="0"/>
    
                            <TextBlock Text="최고 압력 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineA_MaxPress, StringFormat={}{0:F2} atm}" FontWeight="Black" FontSize="20" Foreground="#FFB142" Grid.Row="1" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>

            <ui:Card Margin="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Machine_B" FontSize="22" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,75" HorizontalAlignment="Center"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineB_AvgTemp}" FromValue="0" ToValue="100" TicksForeground="White" Foreground="White" FontWeight="Bold" NeedleFill="DeepSkyBlue" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="60" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="60" ToValue="85" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="85" ToValue="100" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 온도" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineB_AvgTemp, StringFormat={}{0:F1} ℃}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DeepSkyBlue"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineB_AvgPress}" FromValue="0" ToValue="6" TicksForeground="White" Foreground="White" FontWeight="Bold" NeedleFill="Orange" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="3" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="3" ToValue="4.5" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="4.5" ToValue="6" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 압력" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineB_AvgPress, StringFormat={}{0:F2} atm}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Orange"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,50,0,0" BorderBrush="#333333" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="최고 온도 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineB_MaxTemp, StringFormat={}{0:F1} ℃}" FontWeight="Black" FontSize="20" Foreground="#FF5252" Grid.Row="1" Grid.Column="0"/>
                            <TextBlock Text="최고 압력 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineB_MaxPress, StringFormat={}{0:F2} atm}" FontWeight="Black" FontSize="20" Foreground="#FFB142" Grid.Row="1" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>

            <ui:Card Margin="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Machine_C" FontSize="22" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,75" HorizontalAlignment="Center"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineC_AvgTemp}" FromValue="0" ToValue="100" TicksForeground="White" Foreground="White" FontWeight="Bold" NeedleFill="DeepSkyBlue" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="60" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="60" ToValue="85" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="85" ToValue="100" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 온도" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineC_AvgTemp, StringFormat={}{0:F1} ℃}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DeepSkyBlue"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <lvc:AngularGauge Value="{Binding ViewModel.MachineC_AvgPress}" FromValue="0" ToValue="6" TicksForeground="White" Foreground="White" FontWeight="Bold" NeedleFill="Orange" Margin="10" Height="150">
                                <lvc:AngularGauge.Sections>
                                    <lvc:AngularSection FromValue="0" ToValue="3" Fill="#4CAF50"/>
                                    <lvc:AngularSection FromValue="3" ToValue="4.5" Fill="#FFC107"/>
                                    <lvc:AngularSection FromValue="4.5" ToValue="6" Fill="#F44336"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>
                            <TextBlock Text="평균 압력" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding ViewModel.MachineC_AvgPress, StringFormat={}{0:F2} atm}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Orange"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,50,0,0" BorderBrush="#333333" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="최고 온도 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineC_MaxTemp, StringFormat={}{0:F1} ℃}" FontWeight="Black" FontSize="20" Foreground="#FF5252" Grid.Row="1" Grid.Column="0"/>
                            <TextBlock Text="최고 압력 (Max)" Foreground="#AAAAAA" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ViewModel.MachineC_MaxPress, StringFormat={}{0:F2} atm}" FontWeight="Black" FontSize="20" Foreground="#FFB142" Grid.Row="1" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>
        </UniformGrid>
    </Grid>
</Page>