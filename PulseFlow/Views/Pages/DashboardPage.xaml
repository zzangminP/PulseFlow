<Page x:Class="PulseFlow.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:local="clr-namespace:PulseFlow.Views.Pages"
      xmlns:models="clr-namespace:PulseFlow.Models"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
      Title="DashboardPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10,0,20,0">
            <!--<TextBlock Text="Panel" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" /> -->

            <ui:Card Margin="0,0,0,20" Background="MintCream">
                <StackPanel>
                    <TextBlock Text="Master Control" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="전체 가동" Command="{Binding ViewModel.StartAllCommand}" Appearance="Primary" HorizontalAlignment="Stretch" Margin="0,0,5,0"/>
                        <ui:Button Grid.Column="1" Content="전체 정지" Command="{Binding ViewModel.StopAllCommand}" Appearance="Danger" HorizontalAlignment="Stretch" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Machine_A" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="가동 상태 : " VerticalAlignment="Center"/>
                        <ui:ToggleSwitch IsChecked="{Binding ViewModel.IsMachineA_Running}" Command="{Binding ViewModel.ToggleMachineCommand}" CommandParameter="Machine_A" Content="ON/OFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <CheckBox Content="차트에서 선 보이기" IsChecked="{Binding ViewModel.IsMachineA_ChartVisible}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ViewModel.StatusTextA}" Foreground="Gray"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Machine_B" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="가동 상태 : " VerticalAlignment="Center"/>
                        <ui:ToggleSwitch IsChecked="{Binding ViewModel.IsMachineB_Running}" Command="{Binding ViewModel.ToggleMachineCommand}" CommandParameter="Machine_B" Content="ON/OFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <CheckBox Content="차트에서 선 보이기" IsChecked="{Binding ViewModel.IsMachineB_ChartVisible}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ViewModel.StatusTextB}" Foreground="Gray"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Text="Machine_C"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="가동 상태 : " VerticalAlignment="Center"/>
                        <ui:ToggleSwitch IsChecked="{Binding ViewModel.IsMachineC_Running}" Command="{Binding ViewModel.ToggleMachineCommand}" CommandParameter="Machine_C" Content="ON/OFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <CheckBox Content="차트에서 선 보이기" IsChecked="{Binding ViewModel.IsMachineC_ChartVisible}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ViewModel.StatusTextC}" Foreground="Gray"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:Card Grid.Row="0" Margin="0,0,0,10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <TextBlock Text="온도 (Temperature)" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0" Panel.ZIndex="1"/>

                    <lvc:CartesianChart DisableAnimations="True" Margin="0,30,0,0" Height="300">
                        <lvc:CartesianChart.Series>
                            <lvc:LineSeries Title="Machine_A" Values="{Binding ViewModel.TempValuesA}" Visibility="{Binding ViewModel.IsMachineA_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="DeepSkyBlue" PointGeometrySize="0" Fill="Transparent"/>
                            <lvc:LineSeries Title="Machine_B" Values="{Binding ViewModel.TempValuesB}" Visibility="{Binding ViewModel.IsMachineB_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="LimeGreen" PointGeometrySize="0" Fill="Transparent"/>
                            <lvc:LineSeries Title="Machine_C" Values="{Binding ViewModel.TempValuesC}" Visibility="{Binding ViewModel.IsMachineC_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="Orange" PointGeometrySize="0" Fill="Transparent"/>
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="온도(℃)" MinValue="10" MaxValue="90" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <TextBlock Text="압력 (Pressure)" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0" Panel.ZIndex="1"/>

                    <lvc:CartesianChart DisableAnimations="True" Margin="0,30,0,0" Height="300">
                        <lvc:CartesianChart.Series>
                            <lvc:LineSeries Title="Machine_A" Values="{Binding ViewModel.PressValuesA}" Visibility="{Binding ViewModel.IsMachineA_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="DeepSkyBlue" PointGeometrySize="0" Fill="Transparent"/>
                            <lvc:LineSeries Title="Machine_B" Values="{Binding ViewModel.PressValuesB}" Visibility="{Binding ViewModel.IsMachineB_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="LimeGreen" PointGeometrySize="0" Fill="Transparent"/>
                            <lvc:LineSeries Title="Machine_C" Values="{Binding ViewModel.PressValuesC}" Visibility="{Binding ViewModel.IsMachineC_ChartVisible, Converter={StaticResource BoolToVis}}" Stroke="Orange" PointGeometrySize="0" Fill="Transparent"/>
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="압력(atm)" MinValue="0" MaxValue="6" />
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</Page>